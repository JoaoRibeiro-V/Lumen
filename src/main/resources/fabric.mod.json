{
	"schemaVersion": 1,
	"id": "lumora",
	"version": "${version}",
	"name": "Lumora",
	"description": "Lumora is a Minecraft mod that adds bloom effects to glowing blocks using custom shaders and post-processing.",
	"authors": [
		"GioTheDev"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/lumora/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"com.giothedev.lumora.Lumora"
		],
		"client": [
			"com.giothedev.lumora.client.LumoraClient"
		]
	},
	"mixins": [
		"lumora.mixins.json",
		{
			"config": "lumora.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
        "minecraft": "1.21.1",
		"java": ">=21",
		"fabric-api": "*"
	}
}