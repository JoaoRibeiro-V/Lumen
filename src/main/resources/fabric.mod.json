{
	"schemaVersion": 1,
	"id": "lumen",
	"version": "${version}",
	"name": "Lumen",
	"description": "This is an example description! Tell everyone what your mod is about!",
	"authors": [
		"GioTheDev"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/lumen/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"com.giothedev.lumen.Lumen"
		],
		"client": [
			"com.giothedev.lumen.client.LumenClient"
		]
	},
	"mixins": [
		"lumen.mixins.json",
		{
			"config": "lumen.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
        "minecraft": ">=1.21.1 <=1.21.4",
		"java": ">=21",
		"fabric-api": "*"
	}
}